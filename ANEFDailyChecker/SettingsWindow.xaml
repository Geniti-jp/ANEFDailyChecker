<Window x:Class="ANEFDailyChecker.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="設定" Width="400" Height="480">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- メモ追加（テキスト + ボタン） -->
        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <Button Content="追加" DockPanel.Dock="Right" Width="50" Click="AddMemo"/>
            <TextBox x:Name="MemoText" Margin="0,0,5,0" KeyDown="MemoText_KeyDown"/>
        </DockPanel>

        <!-- リセット時刻 -->
        <TextBlock Text="リセット時刻 (hh:mm)" Grid.Row="1" Margin="0,0,0,2"/>
        <TextBox x:Name="ResetTimeBox" Grid.Row="2" Margin="0,0,0,10"/>

        <!-- メモ一覧 -->
        <ListBox x:Name="MemoList" Grid.Row="3" DisplayMemberPath="Text">
            <ListBox.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="編集" Click="EditMemo"/>
                    <MenuItem Header="削除" Click="DeleteMemo"/>
                </ContextMenu>
            </ListBox.ContextMenu>
        </ListBox>

        <!-- 並び替えボタン -->
        <Button Content="↑ 上へ" Grid.Row="4" Margin="0,10,0,5" Click="MoveUp"/>
        <Button Content="↓ 下へ" Grid.Row="5" Margin="0,0,0,10" Click="MoveDown"/>

        <!-- 閉じるボタン -->
        <Button Content="閉じる" Grid.Row="6" Height="28" Click="CloseClick"/>
    </Grid>
</Window>
