<Window x:Class="ANEFDailyChecker.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="設定" Width="400" Height="450">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBox x:Name="MemoText" Grid.Row="0" Margin="0,0,0,5"/>
        <Button Content="追加" Grid.Row="1" Margin="0,0,0,10" Click="AddMemo"/>
        <TextBlock Text="リセット時刻 (hh:mm)" Grid.Row="2" Margin="0,0,0,2"/>
        <TextBox x:Name="ResetTimeBox" Grid.Row="3" Margin="0,0,0,10"/>

        <ListBox x:Name="MemoList" Grid.Row="4" DisplayMemberPath="Text">
            <ListBox.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="編集" Click="EditMemo"/>
                    <MenuItem Header="削除" Click="DeleteMemo"/>
                </ContextMenu>
            </ListBox.ContextMenu>
        </ListBox>

        <Button Content="↑ 上へ" Grid.Row="5" Margin="0,10,0,5" Click="MoveUp"/>
        <Button Content="↓ 下へ" Grid.Row="6" Click="MoveDown"/>
    </Grid>
</Window>