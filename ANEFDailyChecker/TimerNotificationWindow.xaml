<Window x:Class="ANEFDailyChecker.TimerNotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="タイマー終了"
        Width="280" Height="170"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Topmost="True"
        ShowInTaskbar="False">
    <Grid Margin="16,12,16,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
            <TextBlock x:Name="TimerNameText"
                       FontSize="15"
                       FontWeight="Bold"
                       TextAlignment="Center"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0,0,0,4"/>
            <TextBlock Text="タイマー終了"
                       FontSize="13"
                       TextAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="#555555"/>
        </StackPanel>

        <Button Grid.Row="1"
                Content="OK"
                Height="28"
                Width="80"
                HorizontalAlignment="Center"
                Margin="0,8,0,0"
                Click="OkClick"
                IsDefault="True"/>
    </Grid>
</Window>
