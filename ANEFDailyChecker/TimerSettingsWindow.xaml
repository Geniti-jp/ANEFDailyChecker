<Window x:Class="ANEFDailyChecker.TimerSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="タイマー設定" Width="360" Height="400"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 追加ボタン -->
        <Button Grid.Row="0" Content="＋ タイマーを追加"
                HorizontalAlignment="Left" Margin="0,0,0,8"
                Padding="8,4" Click="AddTimer"/>

        <!-- タイマー一覧 -->
        <ListBox x:Name="TimerList" Grid.Row="1" DisplayMemberPath="Name">
            <ListBox.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="編集" Click="EditTimer"/>
                    <MenuItem Header="削除" Click="DeleteTimer"/>
                </ContextMenu>
            </ListBox.ContextMenu>
        </ListBox>

        <!-- 並び替えボタン -->
        <Button Content="↑ 上へ" Grid.Row="2" Margin="0,8,0,4" Click="MoveUp"/>
        <Button Content="↓ 下へ" Grid.Row="3" Margin="0,0,0,8" Click="MoveDown"/>

        <!-- 閉じる -->
        <Button Content="閉じる" Grid.Row="4" Height="28" Click="CloseClick"/>
    </Grid>
</Window>
