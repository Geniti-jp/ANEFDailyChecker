<Window x:Class="ANEFDailyChecker.EditChildWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="子項目の編集" Width="320" Height="620"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 内容 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="内容" Margin="0,0,0,5"/>
            <TextBox x:Name="ItemTextBox"/>
        </StackPanel>

        <!-- リセット日数 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="リセット日数" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="ResetCountBox" Width="50" VerticalAlignment="Center"/>
            <TextBlock Text="日" VerticalAlignment="Center" Margin="4,0,0,0"/>
        </StackPanel>

        <!-- グループモード（孫編集時は非表示） -->
        <CheckBox x:Name="GroupCheckBox" Grid.Row="2" Content="グループモードで使用する"
                  Margin="0,0,0,6" Checked="GroupModeChanged" Unchecked="GroupModeChanged"/>

        <!-- 曜日別モード -->
        <CheckBox x:Name="DayOfWeekCheckBox" Grid.Row="3" Content="曜日別モードで使用する"
                  Margin="0,0,0,10" Checked="DayModeChanged" Unchecked="DayModeChanged"/>

        <!-- 孫項目入力（グループモード時のみ） -->
        <DockPanel x:Name="GrandChildInputArea" Grid.Row="4" Margin="0,0,0,5">
            <Button Content="追加" DockPanel.Dock="Right" Width="50" Click="AddGrandChild"/>
            <TextBox x:Name="GrandChildTextBox" Margin="0,0,5,0" KeyDown="GrandChildTextBox_KeyDown"/>
        </DockPanel>

        <!-- 孫項目リスト（グループモード時のみ） -->
        <ListBox x:Name="GrandChildListBox" Grid.Row="5" DisplayMemberPath="Text">
            <ListBox.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="編集" Click="EditGrandChild"/>
                    <MenuItem Header="削除" Click="DeleteGrandChild"/>
                </ContextMenu>
            </ListBox.ContextMenu>
        </ListBox>

        <Button x:Name="MoveUpBtn"   Content="↑ 上へ" Grid.Row="6" Margin="0,10,0,5" Click="MoveGrandChildUp"/>
        <Button x:Name="MoveDownBtn" Content="↓ 下へ" Grid.Row="7" Margin="0,0,0,10" Click="MoveGrandChildDown"/>

        <!-- 曜日別テキスト（曜日別モード時のみ） -->
        <GroupBox x:Name="DayOfWeekPanel" Grid.Row="8"
                  Header="曜日別テキスト（空欄 = 通常テキストを使用）"
                  Margin="0,0,0,10" Padding="6,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="26"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="日" VerticalAlignment="Center" Margin="0,2"/>
                <TextBox   x:Name="SunBox" Grid.Row="0" Grid.Column="1" Margin="4,2"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="月" VerticalAlignment="Center" Margin="0,2"/>
                <TextBox   x:Name="MonBox" Grid.Row="1" Grid.Column="1" Margin="4,2"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="火" VerticalAlignment="Center" Margin="0,2"/>
                <TextBox   x:Name="TueBox" Grid.Row="2" Grid.Column="1" Margin="4,2"/>
                <TextBlock Grid.Row="3" Grid.Column="0" Text="水" VerticalAlignment="Center" Margin="0,2"/>
                <TextBox   x:Name="WedBox" Grid.Row="3" Grid.Column="1" Margin="4,2"/>
                <TextBlock Grid.Row="4" Grid.Column="0" Text="木" VerticalAlignment="Center" Margin="0,2"/>
                <TextBox   x:Name="ThuBox" Grid.Row="4" Grid.Column="1" Margin="4,2"/>
                <TextBlock Grid.Row="5" Grid.Column="0" Text="金" VerticalAlignment="Center" Margin="0,2"/>
                <TextBox   x:Name="FriBox" Grid.Row="5" Grid.Column="1" Margin="4,2"/>
                <TextBlock Grid.Row="6" Grid.Column="0" Text="土" VerticalAlignment="Center" Margin="0,2"/>
                <TextBox   x:Name="SatBox" Grid.Row="6" Grid.Column="1" Margin="4,2"/>
            </Grid>
        </GroupBox>

        <Button Content="OK" Grid.Row="9" Height="30" Click="OkClick"/>
    </Grid>
</Window>
