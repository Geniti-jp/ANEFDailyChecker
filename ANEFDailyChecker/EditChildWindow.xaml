<Window x:Class="ANEFDailyChecker.EditChildWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="子項目の編集" Width="320" Height="460" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 内容 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="内容" Margin="0,0,0,5"/>
            <TextBox x:Name="TextBox"/>
        </StackPanel>

        <!-- 曜日別モード -->
        <CheckBox x:Name="DayOfWeekCheckBox" Grid.Row="1" Content="曜日別モードで使用する"
                  Margin="0,0,0,10" Checked="DayModeChanged" Unchecked="DayModeChanged"/>

        <!-- 曜日別テキスト設定（曜日別モード時のみ） -->
        <GroupBox x:Name="DayOfWeekPanel" Grid.Row="2"
                  Header="曜日別テキスト（空欄 = 通常テキストを使用）"
                  Margin="0,0,0,10" Padding="6,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="26"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="日" VerticalAlignment="Center" Margin="0,2"/>
                <TextBox   x:Name="SunBox" Grid.Row="0" Grid.Column="1" Margin="4,2"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="月" VerticalAlignment="Center" Margin="0,2"/>
                <TextBox   x:Name="MonBox" Grid.Row="1" Grid.Column="1" Margin="4,2"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="火" VerticalAlignment="Center" Margin="0,2"/>
                <TextBox   x:Name="TueBox" Grid.Row="2" Grid.Column="1" Margin="4,2"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="水" VerticalAlignment="Center" Margin="0,2"/>
                <TextBox   x:Name="WedBox" Grid.Row="3" Grid.Column="1" Margin="4,2"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="木" VerticalAlignment="Center" Margin="0,2"/>
                <TextBox   x:Name="ThuBox" Grid.Row="4" Grid.Column="1" Margin="4,2"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="金" VerticalAlignment="Center" Margin="0,2"/>
                <TextBox   x:Name="FriBox" Grid.Row="5" Grid.Column="1" Margin="4,2"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="土" VerticalAlignment="Center" Margin="0,2"/>
                <TextBox   x:Name="SatBox" Grid.Row="6" Grid.Column="1" Margin="4,2"/>
            </Grid>
        </GroupBox>

        <Button Content="OK" Grid.Row="4" Height="30" Click="OkClick"/>
    </Grid>
</Window>
