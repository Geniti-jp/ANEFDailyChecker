<Window x:Class="ANEFDailyChecker.TimerInputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="タイマー時間を入力" Width="280" Height="200"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleLabel" Grid.Row="0"
                   Text="" FontWeight="Bold"
                   Margin="0,0,0,8"/>

        <TextBlock Grid.Row="1" Text="時間を入力してください（HH:MM）"
                   Margin="0,0,0,6"/>

        <TextBox x:Name="TimeBox" Grid.Row="2"
                 FontSize="16" TextAlignment="Center"
                 MaxLength="5"
                 KeyDown="TimeBox_KeyDown"/>

        <Button Content="開始" Grid.Row="4"
                Height="30" Click="OkClick"/>
    </Grid>
</Window>
