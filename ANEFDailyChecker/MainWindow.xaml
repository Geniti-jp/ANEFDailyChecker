<Window x:Class="ANEFDailyChecker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ANEFDailyChecker"
        Width="400"
        Height="500">

    <Window.Resources>
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ExpandButtonStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="13"/>
            <Setter Property="Height" Value="13"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="2,0,2,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Content" Value="＋"/>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Content" Value="－"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel Margin="10">
        <Grid DockPanel.Dock="Top" Margin="0,0,0,3">
            <TextBlock x:Name="RemainingText" 
                       Text="次回更新まで --時間--分" 
                       VerticalAlignment="Center" 
                       FontSize="12" Margin="2,0,0,0" Height="20"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="再読込" Width="60" Margin="0,0,5,0" Click="ReloadClick"/>
                <Button Content="設定" Width="60" Click="OpenSettings"/>
            </StackPanel>
        </Grid>

        <ListBox x:Name="MemoList" BorderThickness="1" BorderBrush="#CCCCCC" HorizontalContentAlignment="Stretch">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="2">
                        <Grid Height="15">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox IsChecked="{Binding IsChecked}" 
                                          VerticalAlignment="Center"
                                          PreviewMouseDown="ParentCheckPreview"
                                          Click="ParentCheckChanged"/>

                                <ToggleButton x:Name="ExpandBtn" 
                                              Style="{StaticResource ExpandButtonStyle}"
                                              Visibility="{Binding IsGroup, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                <TextBlock Text="{Binding DisplayText}" 
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           Margin="0"/>
                            </StackPanel>
                        </Grid>

                        <ItemsControl ItemsSource="{Binding Children}" 
                                      Margin="20,0,0,0"
                                      Visibility="{Binding IsChecked, ElementName=ExpandBtn, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Height="15">
                                        <CheckBox IsChecked="{Binding IsChecked}" 
                                                  VerticalAlignment="Center" 
                                                  Click="ChildCheckChanged">
                                            <TextBlock Text="{Binding Text}" FontSize="12"/>
                                        </CheckBox>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>
